# Copy file này thành .env và điền giá trị thật
# cp .env.example .env

# === DeepSeek (bắt buộc) ===
# Lấy tại: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# === Telegram Bot (tùy chọn) ===
# Tạo bot qua @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=

# === Zalo Bot (tùy chọn) ===
# Lấy từ Zalo Bot Platform: https://bot.zaloplatforms.com
# Format: numeric_id:secret
ZALO_BOT_TOKEN=

# === Linear (tùy chọn) ===
# Lấy tại: https://linear.app/settings/api
LINEAR_API_KEY=

# === OpenClaw Gateway (tùy chọn) ===
# Token tự đặt để bảo vệ gateway endpoint nội bộ
# Nếu bỏ trống, gateway sẽ tự sinh token ngẫu nhiên
OPENCLAW_GATEWAY_TOKEN=

# === Server Port ===
PORT=3000
