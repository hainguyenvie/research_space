# Copy file này thành .env và điền giá trị thật
# cp .env.example .env

# === DeepSeek (bắt buộc) ===
# Lấy tại: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# === Telegram Bot (tùy chọn) ===
# Tạo bot qua @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=

# === Zalo Bot (tùy chọn) ===
# Lấy từ Zalo Bot Platform: https://bot.zaloplatforms.com
# Format: numeric_id:secret
ZALO_BOT_TOKEN=

# === Linear (cần cho skill daily-report) ===
# Lấy tại: https://linear.app/settings/api
LINEAR_API_KEY=

# === OpenClaw Gateway (tùy chọn) ===
# Token tự đặt để bảo vệ gateway endpoint nội bộ
# Nếu bỏ trống, gateway sẽ tự sinh token ngẫu nhiên
OPENCLAW_GATEWAY_TOKEN=

# === Server Port ===
PORT=3000

# === Google Docs / Drive (cần cho skill daily-report) ===
# Tạo OAuth client (Desktop type) tại: https://console.cloud.google.com/auth/clients
# Enable: Google Docs API + Google Drive API
# Scope yêu cầu: documents + drive (full)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Chạy `pnpm --filter @workspace/scripts run oauth:google` để lấy refresh token
GOOGLE_REFRESH_TOKEN=
# Folder ID lấy từ URL: https://drive.google.com/drive/folders/<ID>
GOOGLE_DOCS_REPORT_FOLDER_ID=
# Tên doc chính thức (sẽ tự tạo trong folder trên nếu chưa có).
# Lưu ý quote nếu value chứa space (cho khả năng `source .env` từ bash).
GOOGLE_DOCS_REPORT_DOC_NAME="Báo cáo công việc — Resuck Excellent"
